<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manga Track — Comic & Manga Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *{margin:0;padding:0;box-sizing:border-box}
  :root{--gold:#C9A84C;--gold-light:#E8C97A;--gold-dim:#8B6E30;--bg:#0A0A0C;--surface:#111116;--surface2:#18181F;--surface3:#1F1F28;--border:#2A2A35;--border-soft:#222230;--text:#F0EEE8;--text-muted:#8A8899;--text-dim:#55546A;--red:#E05555;--green:#5EC47A;--blue:#5B8DEF;--purple:#9B6BF0;--pink:#E86F9C;--orange:#E8A75C;--serif:'Cormorant Garamond',serif;--sans:'DM Sans',sans-serif}
  body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh}
  
  /* Header Styles */
  header{position:sticky;top:0;z-index:100;background:rgba(10,10,12,.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--border-soft);padding:0 2rem;height:70px;display:flex;align-items:center;justify-content:space-between}
  .logo{font-family:var(--serif);font-size:1.6rem;font-weight:300;letter-spacing:.2em;color:var(--gold);text-transform:uppercase}
  .logo span{color:var(--text-dim);font-style:italic}
  .tagline{font-family:var(--sans);font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:var(--text-dim);border-left:1px solid var(--border);padding-left:1rem}
  .tagline em{color:var(--gold-light)}
  .btn{font-family:var(--sans);font-size:.75rem;font-weight:500;padding:.45rem 1rem;border-radius:2px;border:1px solid var(--border);background:transparent;color:var(--text-muted);cursor:pointer;transition:.2s}
  .btn:hover{border-color:var(--gold-dim);color:var(--gold)}
  .btn-primary{background:linear-gradient(115deg, var(--gold) 0%, var(--gold-dim) 100%);border-color:transparent;color:#0A0A0C}
  .btn-primary:hover{background:linear-gradient(115deg, var(--gold-light) 0%, var(--gold) 100%)}
  
  /* Sync Bar */
  .sync-bar{background:var(--surface);border-bottom:1px solid var(--border-soft);padding:.3rem 2rem;display:flex;align-items:center;gap:.6rem;font-size:.7rem;color:var(--text-dim)}
  .sync-dot{width:6px;height:6px;border-radius:50%;background:var(--text-dim)}
  .sync-dot.online{background:var(--green)}
  .sync-dot.syncing{background:var(--gold);animation:pulse 1s infinite}
  .sync-dot.error{background:var(--red)}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
  
  /* Stats Bar */
  .stats-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border-soft)}
  .stat-item{background:var(--surface);padding:1rem 1.5rem;cursor:pointer;transition:.2s}
  .stat-item:hover{background:var(--surface2)}
  .stat-label{font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-dim)}
  .stat-value{font-family:var(--serif);font-size:1.8rem;font-weight:300;color:var(--text)}
  
  /* Main Layout */
  main{display:grid;grid-template-columns:240px 1fr;min-height:calc(100vh - 110px)}
  aside{background:var(--surface);border-right:1px solid var(--border-soft);padding:1.5rem 0;position:sticky;top:70px;height:calc(100vh - 70px);overflow-y:auto}
  .sidebar-section{padding:0 1rem;margin-bottom:1.5rem}
  .sidebar-title{font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:var(--text-dim);border-bottom:1px solid var(--border-soft);padding-bottom:.4rem;margin-bottom:.6rem}
  .nav-item{display:flex;align-items:center;gap:.6rem;padding:.5rem .6rem;cursor:pointer;color:var(--text-muted);font-size:.8rem}
  .nav-item:hover{background:var(--surface2);color:var(--text)}
  .nav-item.active{background:rgba(201,168,76,.08);color:var(--gold);border-left:2px solid var(--gold)}
  .content{padding:1.5rem;background:var(--bg)}
  .section-title{font-family:var(--serif);font-size:1.5rem;font-weight:300;margin-bottom:1rem}
  .section-title em{color:var(--gold)}
  
  /* Search & Grid */
  .search-row{display:flex;gap:.75rem;margin-bottom:1rem}
  .search-wrap{flex:1;position:relative}
  .search-input{width:100%;background:var(--surface);border:1px solid var(--border);color:var(--text);padding:.5rem 1rem .5rem 2rem;border-radius:2px;font-size:.8rem}
  .search-icon{position:absolute;left:.6rem;top:50%;transform:translateY(-50%);font-size:.8rem}
  select.filter-select{background:var(--surface);border:1px solid var(--border);color:var(--text);padding:.5rem;border-radius:2px;font-size:.8rem}
  .media-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:1rem}
  .media-card{background:var(--surface);border:1px solid var(--border-soft);border-radius:2px;overflow:hidden;cursor:pointer;transition:.2s;position:relative}
  .media-card:hover{border-color:var(--gold-dim);transform:translateY(-2px)}
  .card-poster{width:100%;aspect-ratio:2/3;object-fit:cover}
  .poster-placeholder{width:100%;aspect-ratio:2/3;display:flex;align-items:center;justify-content:center;background:var(--surface2);font-size:2rem;color:var(--text-dim)}
  .card-badge{position:absolute;top:.4rem;right:.4rem;font-size:.6rem;padding:.2rem .4rem;border-radius:2px;background:rgba(0,0,0,.7)}
  .card-info{padding:.6rem}
  .card-title{font-size:.75rem;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .card-meta{font-size:.65rem;color:var(--text-dim)}
  .star-row{display:flex;gap:.1rem;margin-top:.3rem}
  .star{font-size:.6rem;color:var(--text-dim)}.star.filled{color:var(--gold)}
  .progress-bar{height:2px;background:var(--border);margin-top:.4rem}
  .progress-fill{height:100%;background:var(--gold)}
  
  /* Modal */
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:200;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:.2s}
  .modal-overlay.open{opacity:1;pointer-events:all}
  .modal{background:var(--surface);border:1px solid var(--border);width:100%;max-width:650px;max-height:85vh;overflow-y:auto;border-radius:4px}
  .modal-header{padding:1rem 1.5rem;border-bottom:1px solid var(--border-soft);display:flex;justify-content:space-between;align-items:center}
  .modal-title{font-family:var(--serif);font-size:1.2rem;font-weight:300}
  .modal-body{padding:1.2rem 1.5rem}
  .tmdb-wrap{position:relative;margin-bottom:1rem}
  .tmdb-input{width:100%;background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:.5rem .8rem;border-radius:2px;font-size:.8rem}
  .tmdb-dropdown{position:absolute;top:100%;left:0;right:0;background:var(--surface2);border:1px solid var(--border);border-top:none;max-height:250px;overflow-y:auto;display:none;z-index:50}
  .tmdb-item{display:flex;gap:.6rem;padding:.5rem .8rem;cursor:pointer;border-bottom:1px solid var(--border-soft)}
  .tmdb-item:hover{background:var(--surface3)}
  .tmdb-thumb{width:32px;height:48px;object-fit:cover;border-radius:2px}
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:.8rem}
  .form-group{display:flex;flex-direction:column;gap:.3rem}
  .form-group.full{grid-column:1/-1}
  label{font-size:.65rem;letter-spacing:.08em;text-transform:uppercase;color:var(--text-dim)}
  input,select,textarea{background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:.5rem .7rem;border-radius:2px;font-size:.8rem}
  .star-rating{display:flex;gap:.2rem}
  .star-btn{background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--text-dim)}
  .star-btn.active{color:var(--gold)}
  .poster-box{margin-right:1rem;flex-shrink:0}
  .poster-ph{width:70px;height:105px;background:var(--surface2);display:flex;align-items:center;justify-content:center;border-radius:2px;font-size:1.5rem}
  .add-layout{display:flex;gap:1rem;margin-bottom:1rem;align-items:flex-start}
  .modal-footer{display:flex;justify-content:flex-end;gap:.5rem;margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border-soft)}
  .toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--surface);border:1px solid var(--gold-dim);padding:.5rem 1rem;border-radius:2px;font-size:.8rem;z-index:500;opacity:0;transition:.2s}
  .toast.show{opacity:1}
  .toast.error{border-color:var(--red);color:var(--red)}
  .empty{text-align:center;padding:3rem;color:var(--text-dim)}
  
  @media(max-width:700px){main{grid-template-columns:1fr}aside{display:none}.stats-bar{grid-template-columns:repeat(2,1fr)}.form-grid{grid-template-columns:1fr}.form-group.full{grid-column:1}}
</style>
</head>
<body>

<div class="sync-bar">
  <span class="sync-dot" id="sync-dot"></span>
  <span id="sync-status">Connecting...</span>
</div>

<header>
  <div style="display:flex;align-items:baseline;gap:.8rem">
    <div class="logo">Manga<span>Track</span></div>
    <div class="tagline">track your <em>manga</em> & <em>manhwa</em> journey</div>
  </div>
  <div>
    <button class="btn" onclick="loadFromSheets()">↻ Sync</button>
    <button class="btn btn-primary" onclick="openModal()">+ Add Manga</button>
  </div>
</header>

<div class="stats-bar">
  <div class="stat-item" onclick="filterStatus('all')"><div class="stat-label">Total</div><div class="stat-value" id="stat-total">0</div></div>
  <div class="stat-item" onclick="filterStatus('reading')"><div class="stat-label">Reading</div><div class="stat-value" id="stat-reading">0</div></div>
  <div class="stat-item" onclick="filterStatus('completed')"><div class="stat-label">Completed</div><div class="stat-value" id="stat-completed">0</div></div>
  <div class="stat-item" onclick="filterStatus('plan')"><div class="stat-label">Plan to Read</div><div class="stat-value" id="stat-plan">0</div></div>
</div>

<main>
  <aside>
    <div class="sidebar-section">
      <div class="sidebar-title">Status</div>
      <div class="nav-item active" id="nav-all" onclick="filterStatus('all')">📚 All Manga</div>
      <div class="nav-item" id="nav-reading" onclick="filterStatus('reading')">📖 Reading</div>
      <div class="nav-item" id="nav-completed" onclick="filterStatus('completed')">✅ Completed</div>
      <div class="nav-item" id="nav-plan" onclick="filterStatus('plan')">📋 Plan to Read</div>
      <div class="nav-item" id="nav-dropped" onclick="filterStatus('dropped')">⛔ Dropped</div>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-title">Type</div>
      <div class="nav-item" id="nav-type-all" onclick="filterType('all')">◈ All</div>
      <div class="nav-item" id="nav-type-manga" onclick="filterType('Manga')">📘 Manga</div>
      <div class="nav-item" id="nav-type-manhwa" onclick="filterType('Manhwa')">📱 Manhwa</div>
      <div class="nav-item" id="nav-type-manhua" onclick="filterType('Manhua')">📙 Manhua</div>
    </div>
  </aside>

  <div class="content">
    <div class="section-title" id="section-title">My <em>Manga Collection</em></div>
    <div class="search-row">
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input class="search-input" type="text" placeholder="Search manga, author, genre..." id="search-input" oninput="renderMedia()">
      </div>
      <select id="sort-select" onchange="renderMedia()" class="filter-select">
        <option value="added">Recently Added</option>
        <option value="rating">Highest Rated</option>
        <option value="title">A → Z</option>
      </select>
    </div>
    <div id="media-container"></div>
  </div>
</main>

<!-- Modal Add/Edit Manga -->
<div class="modal-overlay" id="modal-overlay" onclick="closeModalOutside(event)">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="modal-heading">Add New Manga</div>
      <button class="btn" onclick="closeModal()" style="padding:.2rem .6rem">✕</button>
    </div>
    <div class="modal-body">
      <!-- AniList Search -->
      <div style="margin-bottom:1rem">
        <label>Cari dari AniList (gambar otomatis)</label>
        <div class="tmdb-wrap">
          <div class="tmdb-row">
            <input class="tmdb-input" id="anilist-search" type="text" placeholder="Ketik judul manga/manhwa..." oninput="onAnilistSearch(this.value)" autocomplete="off">
            <button class="btn" onclick="clearAnilist()" style="padding:.3rem .6rem">✕</button>
          </div>
