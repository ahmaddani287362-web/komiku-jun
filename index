                <button class="star-btn" data-v="2" onclick="setRating(2)">★</button>
                <button class="star-btn" data-v="3" onclick="setRating(3)">★</button>
                <button class="star-btn" data-v="4" onclick="setRating(4)">★</button>
                <button class="star-btn" data-v="5" onclick="setRating(5)">★</button>
              </div>
            </div>
            <div class="form-group full">
              <label>Notes</label>
              <textarea id="f-notes" rows="2" placeholder="Personal thoughts..."></textarea>
            </div>
          </div>
        </div>
      </div>
      
      <input type="hidden" id="f-cover" value="">
      <input type="hidden" id="f-anilist-id" value="">

      <div class="modal-footer">
        <button class="btn" onclick="closeModal()">Cancel</button>
        <button class="btn btn-primary" id="btn-save" onclick="saveEntry()">Save Manga</button>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ==================== GOOGLE SHEETS API ====================
// ⚠️ GANTI URL INI DENGAN URL APPS SCRIPT ANDA ⚠️
const API_SHEETS = 'https://script.google.com/macros/s/AKfycbw7BjczrAVkCTdumUlXPZbWZLGpbs71O_FjqEkH5K_vCwaQKC1WAuoZ6GHdAG_dUD7M/exec';

// ==================== ANILIST API ====================
const ANILIST_API = 'https://graphql.anilist.co';

// ==================== DATA ====================
let mediaData = [];
let currentRating = 0;
let editingId = null;
let filterSt = 'all';
let filterTy = 'all';
let viewMode = 'grid';
let anilistTimer = null;

// ==================== SYNC FUNCTIONS ====================
function setSyncStatus(status, message) {
  const dot = document.getElementById('sync-dot');
  const text = document.getElementById('sync-status');
  if (dot) dot.className = 'sync-dot ' + status;
  if (text) text.textContent = message;
}

function showToast(msg, isError) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (isError ? ' error' : '');
  setTimeout(() => t.classList.remove('show'), 2500);
}

async function apiSheets(body) {
  const response = await fetch(API_SHEETS, {
    method: 'POST',
    body: JSON.stringify(body)
  });
  const text = await response.text();
  try {
    return JSON.parse(text);
  } catch (e) {
    throw new Error('Server error: ' + text.substring(0, 100));
  }
}

async function loadFromSheets() {
  setSyncStatus('syncing', 'Loading...');
  try {
    const response = await fetch(API_SHEETS + '?action=getAll');
    const data = await response.json();
    if (data.error) throw new Error(data.error);
    
    mediaData = (data.manga || []).map(m => ({
      id: Number(m.id || 0),
      title: String(m.title || ''),
      type: String(m.type || 'Manga'),
      year: Number(m.year || 0),
      status: String(m.status || 'plan'),
      genre: String(m.genre || ''),
      author: String(m.author || ''),
      chapters: Number(m.chapters || 0),
      currentChapter: Number(m.currentChapter || 0),
      volumes: String(m.volumes || ''),
      rating: Number(m.rating || 0),
      notes: String(m.notes || ''),
      added: Number(m.added || 0),
      cover: String(m.cover || ''),
      anilistId: String(m.anilistId || m.tmdbid || '')
    }));
    
    setSyncStatus('online', 'Synced');
    renderMedia();
  } catch (err) {
    setSyncStatus('error', 'Error: ' + err.message);
    // Fallback ke localStorage jika Sheets error
    loadFromStorage();
  }
}

// Fallback ke localStorage
function loadFromStorage() {
  const saved = localStorage.getItem('mangaTracker');
  if (saved) {
    mediaData = JSON.parse(saved);
    renderMedia();
  }
}

function saveToStorage() {
  localStorage.setItem('mangaTracker', JSON.stringify(mediaData));
}

// ==================== ANILIST SEARCH ====================
async function searchAnilist(query) {
  const searchQuery = `
    query ($search: String) {
      Media (search: $search, type: MANGA) {
        id
        title { romaji english native }
        coverImage { large }
        startDate { year }
        chapters
        volumes
        genres
        staff {
          edges {
            node { name { full } primaryOccupations }
          }
        }
      }
    }
  `;
  
  try {
    const response = await fetch(ANILIST_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query: searchQuery, variables: { search: query } })
    });
    const data = await response.json();
    return data.data?.Media || null;
  } catch (err) {
    console.error('AniList error:', err);
    return null;
  }
}

function onAnilistSearch(value) {
  clearTimeout(anilistTimer);
  if (value.length < 2) {
    document.getElementById('anilist-dd').style.display = 'none';
    return;
  }
  anilistTimer = setTimeout(async () => {
    const manga = await searchAnilist(value);
    const dd = document.getElementById('anilist-dd');
    
    if (!manga) {
      dd.style.display = 'none';
      return;
    }
    
    let author = '';
    if (manga.staff?.edges) {
      const authorEdge = manga.staff.edges.find(edge => 
        edge.node.primaryOccupations?.some(occ => occ.includes('Author') || occ.includes('Writer'))
      );
      if (authorEdge) author = authorEdge.node.name.full;
    }
    
    dd.innerHTML = `
      <div class="tmdb-item" onclick="selectAnilistManga(this)" 
           data-id="${manga.id}"
           data-title="${manga.title.romaji || manga.title.english || manga.title.native}"
           data-cover="${manga.coverImage?.large || ''}"
           data-year="${manga.startDate?.year || ''}"
           data-chapters="${manga.chapters || ''}"
           data-volumes="${manga.volumes || ''}"
           data-genres="${(manga.genres || []).slice(0,3).join(', ')}"
           data-author="${author}">
        ${manga.coverImage?.large ? `<img class="tmdb-thumb" src="${manga.coverImage.large}">` : `<div class="tmdb-nothumb">${(manga.title.romaji || '?').charAt(0)}</div>`}
        <div>
          <div class="tmdb-name">${manga.title.romaji || manga.title.english}</div>
          <div class="tmdb-sub">${manga.genres?.slice(0,2).join(', ') || ''} · ${manga.chapters || '?'} ch</div>
        </div>
      </div>
    `;
    dd.style.display = 'block';
  }, 400);
}

function selectAnilistManga(el) {
  document.getElementById('f-title').value = el.dataset.title;
  document.getElementById('f-year').value = el.dataset.year;
  document.getElementById('f-chapters').value = el.dataset.chapters;
  document.getElementById('f-volumes').value = el.dataset.volumes;
  document.getElementById('f-genre').value = el.dataset.genres;
  document.getElementById('f-author').value = el.dataset.author;
  document.getElementById('f-cover').value = el.dataset.cover;
  document.getElementById('f-anilist-id').value = el.dataset.id;
  document.getElementById('anilist-search').value = el.dataset.title;
  
  updateCoverPreview(el.dataset.cover, el.dataset.title);
  document.getElementById('anilist-dd').style.display = 'none';
}

function updateCoverPreview(url, title) {
  const box = document.getElementById('poster-box');
  const letter = (title || '?').charAt(0).toUpperCase();
  if (url && url !== 'null' && url !== '') {
    box.innerHTML = `<img class="poster-ph" src="${url}" style="width:70px;height:105px;object-fit:cover" onerror="this.outerHTML='<div class=poster-ph>${letter}</div>';">`;
  } else {
    box.innerHTML = `<div class="poster-ph">${letter}</div>`;
  }
}

function clearAnilist() {
  document.getElementById('anilist-search').value = '';
  document.getElementById('f-cover').value = '';
  document.getElementById('f-anilist-id').value = '';
  document.getElementById('anilist-dd').style.display = 'none';
  updateCoverPreview('', document.getElementById('f-title').value);
}

// ==================== CORE FUNCTIONS ====================
async function saveEntry() {
  const title = document.getElementById('f-title').value.trim();
  if (!title) {
    showToast('Please enter a title', true);
    return;
  }
  
  const entry = {
    id: editingId || Date.now(),
    title: title,
    type: document.getElementById('f-type').value,
    year: parseInt(document.getElementById('f-year').value) || new Date().getFullYear(),
    status: document.getElementById('f-status').value,
    genre: document.getElementById('f-genre').value || '',
    author: document.getElementById('f-author').value || '',
    chapters: parseInt(document.getElementById('f-chapters').value) || 0,
    currentChapter: parseInt(document.getElementById('f-current-chapter').value) || 0,
    volumes: document.getElementById('f-volumes').value || '',
    rating: currentRating,
    notes: document.getElementById('f-notes').value || '',
    cover: document.getElementById('f-cover').value || '',
    anilistId: document.getElementById('f-anilist-id').value || '',
    added: editingId ? (mediaData.find(x => x.id === editingId)?.added || Date.now()) : Date.now()
  };
  
  setSyncStatus('syncing', 'Saving...');
  
  try {
    await apiSheets({ action: 'save', manga: entry });
    
    if (editingId) {
      const idx = mediaData.findIndex(x => x.id === editingId);
      if (idx > -1) mediaData[idx] = entry;
    } else {
      mediaData.push(entry);
    }
    
    saveToStorage();
    renderMedia();
    closeModal();
    setSyncStatus('online', 'Saved!');
    showToast(editingId ? 'Updated!' : 'Saved!');
  } catch (err) {
    setSyncStatus('error', 'Save failed');
    showToast('Error: ' + err.message, true);
    // Fallback ke localStorage
    if (editingId) {
      const idx = mediaData.findIndex(x => x.id === editingId);
      if (idx > -1) mediaData[idx] = entry;
    } else {
      mediaData.push(entry);
    }
    saveToStorage();
    renderMedia();
    closeModal();
  }
}

function getFiltered() {
  let data = [...mediaData];
  if (filterSt !== 'all') data = data.filter(x => x.status === filterSt);
  if (filterTy !== 'all') data = data.filter(x => x.type === filterTy);
  
  const q = document.getElementById('search-input').value.toLowerCase();
  if (q) {
    data = data.filter(x => 
      x.title.toLowerCase().includes(q) || 
      (x.author && x.author.toLowerCase().includes(q)) ||
      (x.genre && x.genre.toLowerCase().includes(q))
    );
  }
  
  const sort = document.getElementById('sort-select').value;
  if (sort === 'rating') data.sort((a, b) => b.rating - a.rating);
  else if (sort === 'title') data.sort((a, b) => a.title.localeCompare(b.title));
  else data.sort((a, b) => b.added - a.added);
  
  return data;
}

function renderMedia() {
  updateStats();
  const data = getFiltered();
  const container = document.getElementById('media-container');
  
  if (!data.length) {
    container.innerHTML = '<div class="empty">📭 No manga found<br><small>Add your first manga using the + button</small></div>';
    return;
  }
  
  container.innerHTML = `<div class="media-grid">${data.map(m => cardHTML(m)).join('')}</div>`;
}

function cardHTML(m) {
  const letter = m.title.charAt(0).toUpperCase();
  const progress = m.chapters ? Math.round((m.currentChapter / m.chapters) * 100) : 0;
  const typeIcons = { Manga: '📘', Manhwa: '📱', Manhua: '📙' };
  const statusIcons = { reading: '📖', completed: '✅', plan: '📋', dropped: '⛔' };
  
  return `
    <div class="media-card" onclick="showDetail(${m.id})">
      ${m.cover ? `<img class="card-poster" src="${m.cover}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">` : ''}
      <div class="poster-placeholder" style="${m.cover ? 'display:none' : 'display:flex'}">${letter}</div>
      <div class="card-badge">${statusIcons[m.status] || '📚'}</div>
      <div class="card-info">
        <div class="card-title">${m.title}</div>
        <div class="card-meta">${typeIcons[m.type] || '📘'} ${m.type} · ${m.year || '?'}</div>
        <div class="card-meta">📖 ${m.currentChapter || 0}/${m.chapters || '?'}</div>
        ${m.rating ? `<div class="star-row">${renderStars(m.rating)}</div>` : ''}
        ${progress > 0 && progress < 100 ? `<div class="progress-bar"><div class="progress-fill" style="width:${progress}%"></div></div>` : ''}
      </div>
    </div>
  `;
}

function renderStars(rating) {
  return [1,2,3,4,5].map(i => `<span class="star${i <= rating ? ' filled' : ''}">★</span>`).join('');
}

function updateStats() {
  document.getElementById('stat-total').textContent = mediaData.length;
  document.getElementById('stat-reading').textContent = mediaData.filter(x => x.status === 'reading').length;
  document.getElementById('stat-completed').textContent = mediaData.filter(x => x.status === 'completed').length;
  document.getElementById('stat-plan').textContent = mediaData.filter(x => x.status === 'plan').length;
}

function filterStatus(status) {
  filterSt = status;
  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
  if (status === 'all') document.getElementById('nav-all')?.classList.add('active');
  else document.getElementById('nav-' + status)?.classList.add('active');
  renderMedia();
}

function filterType(type) {
  filterTy = type;
  document.querySelectorAll('[id^="nav-type-"]').forEach(el => el.classList.remove('active'));
  if (type === 'all') document.getElementById('nav-type-all')?.classList.add('active');
  else document.getElementById('nav-type-' + type.toLowerCase())?.classList.add('active');
  renderMedia();
}

function openModal(id) {
  editingId = id || null;
  const m = id ? mediaData.find(x => x.id === id) : null;
  
  document.getElementById('modal-heading').textContent = m ? 'Edit Manga' : 'Add New Manga';
  document.getElementById('f-title').value = m ? m.title : '';
  document.getElementById('f-type').value = m ? m.type : 'Manga';
  document.getElementById('f-year').value = m ? m.year : '';
  document.getElementById('f-status').value = m ? m.status : 'plan';
  document.getElementById('f-genre').value = m ? m.genre : '';
  document.getElementById('f-author').value = m ? m.author : '';
  document.getElementById('f-chapters').value = m ? m.chapters : '';
  document.getElementById('f-current-chapter').value = m ? m.currentChapter : '';
  document.getElementById('f-volumes').value = m ? m.volumes : '';
  document.getElementById('f-notes').value = m ? m.notes : '';
  document.getElementById('f-cover').value = m ? m.cover : '';
  document.getElementById('f-anilist-id').value = m ? m.anilistId : '';
  
  setRating(m ? m.rating : 0);
  updateCoverPreview(m ? m.cover : '', m ? m.title : '');
  document.getElementById('modal-overlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
  editingId = null;
}

function closeModalOutside(e) {
  if (e.target === document.getElementById('modal-overlay')) closeModal();
}

function setRating(v) {
  currentRating = v;
  document.querySelectorAll('.star-btn').forEach(b => b.classList.toggle('active', parseInt(b.dataset.v) <= v));
}

function showDetail(id) {
  const m = mediaData.find(x => x.id === id);
  if (!m) return;
  
  const progress = m.chapters ? Math.round((m.currentChapter / m.chapters) * 100) : 0;
  alert(`📖 ${m.title}\n\nType: ${m.type}\nStatus: ${m.status}\nAuthor: ${m.author || '-'}\nProgress: ${m.currentChapter || 0}/${m.chapters || '?'} chapters (${progress}%)\nRating: ${m.rating}/5\n\nNotes: ${m.notes || '-'}`);
}

async function deleteEntry(id) {
  if (!confirm('Remove this manga?')) return;
  setSyncStatus('syncing', 'Deleting...');
  try {
    await apiSheets({ action: 'delete', id: id });
    mediaData = mediaData.filter(x => x.id !== id);
    saveToStorage();
    renderMedia();
    setSyncStatus('online', 'Deleted');
    showToast('Removed');
  } catch (err) {
    showToast('Delete failed', true);
  }
}

// Close dropdown on click outside
document.addEventListener('click', e => {
  if (!e.target.closest('.tmdb-wrap')) {
    document.getElementById('anilist-dd').style.display = 'none';
  }
});

// Initialize
loadFromSheets();
</script>
</body>
